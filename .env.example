# PlagLe API - Environment Configuration
# Copy this file to .env and update with your values

# Application Settings
APP_NAME="PlagLe API"
APP_VERSION="1.0.0"
DEBUG=False

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=plagle_db

# File Storage
UPLOAD_DIR=uploads
REPORT_DIR=reports
MAX_FILE_SIZE=10485760  # 10MB in bytes
# ALLOWED_EXTENSIONS=[".txt", ".pdf", ".docx"]  # Configured in code

# Plagiarism Detection
SIMILARITY_THRESHOLD=0.15  # 15% similarity triggers alert
ALGORITHM_ID=1

# CORS - Add your frontend URLs
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]  # Configured in code

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Production Deployment (AWS EC2)
# Update these for production:
# DB_HOST=your-rds-endpoint.amazonaws.com
# CORS_ORIGINS=["https://your-frontend-domain.com"]
